{
	"compilerOptions": {
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"esModuleInterop": true,
		"isolatedModules": true,
		"skipLibCheck": true,
		"target": "es2015",
		"types": ["bun"],
		"declaration": true,
		"outDir": "./dist",
		"rootDir": "./src"
	},
	"include": ["./src"]
}
